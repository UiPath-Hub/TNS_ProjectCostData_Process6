                                                                                                                                            <ui:InvokeCode ContinueOnError="{x:Null}" Code="' กำหนดค่าเริ่มต้น&#xA;out_IsSuccess = True&#xA;out_ErrorMessage = String.Empty&#xA;&#xA;Dim xlApp As Microsoft.Office.Interop.Excel.Application = Nothing&#xA;Dim xlWorkBook As Microsoft.Office.Interop.Excel.Workbook = Nothing&#xA;Dim xlWorkSheet As Microsoft.Office.Interop.Excel.Worksheet = Nothing&#xA;&#xA;Try&#xA;    ' 1. ตรวจสอบ Arguments (ดัก Error ไว้ก่อน)&#xA;    If String.IsNullOrWhiteSpace(fullFilePath) Then Throw New Exception(&quot;ลืมระบุค่าตัวแปร 'fullFilePath'&quot;)&#xA;    If String.IsNullOrWhiteSpace(sheetName) Then Throw New Exception(&quot;ลืมระบุค่าตัวแปร 'sheetName'&quot;)&#xA;    If String.IsNullOrWhiteSpace(cellAddress) Then Throw New Exception(&quot;ลืมระบุค่าตัวแปร 'cellAddress'&quot;)&#xA;    If String.IsNullOrWhiteSpace(colorInput) Then Throw New Exception(&quot;ลืมระบุค่าตัวแปร 'colorInput'&quot;)&#xA;&#xA;    ' 2. ใช้ GetObject ระบุ Path ตรงๆ (จับไฟล์เป้าหมายได้แม่นยำแม้เปิดหลายไฟล์)&#xA;    xlWorkBook = CType(Microsoft.VisualBasic.Interaction.GetObject(fullFilePath), Microsoft.Office.Interop.Excel.Workbook)&#xA;    xlApp = xlWorkBook.Application&#xA;&#xA;    ' --- บังคับให้ Excel ปรากฏตัวและอัปเดตหน้าจอ ---&#xA;    xlApp.Visible = True&#xA;    xlApp.ScreenUpdating = True&#xA;&#xA;    ' 3. เชื่อมต่อไปยัง Worksheet&#xA;    Try&#xA;        xlWorkSheet = CType(xlWorkBook.Sheets(sheetName), Microsoft.Office.Interop.Excel.Worksheet)&#xA;        &#xA;        ' บังคับคลิกชีตนี้ให้แสดงขึ้นมาบนจอ เผื่อผู้ใช้เปิดชีตอื่นค้างไว้&#xA;        xlWorkSheet.Activate() &#xA;    Catch ex As Exception&#xA;        Throw New Exception(&quot;ไม่พบ Sheet ที่ชื่อว่า '&quot; &amp; sheetName &amp; &quot;'&quot;)&#xA;    End Try&#xA;&#xA;    If xlWorkSheet Is Nothing Then Throw New Exception(&quot;ตัวแปร Sheet มีค่าเป็นว่าง&quot;)&#xA;&#xA;    ' 4. จัดการสี&#xA;    Dim selectedColor As System.Drawing.Color&#xA;    If colorInput.Trim().StartsWith(&quot;#&quot;) Then&#xA;        selectedColor = System.Drawing.ColorTranslator.FromHtml(colorInput.Trim())&#xA;    Else&#xA;        selectedColor = System.Drawing.Color.FromName(colorInput.Trim())&#xA;    End If&#xA;&#xA;    ' 5. เทสีลงเซลล์&#xA;    xlWorkSheet.Range(cellAddress.Trim()).Interior.Color = System.Drawing.ColorTranslator.ToOle(selectedColor)&#xA;&#xA;    ' --- 6. สั่ง Save ไฟล์ (แต่ไม่ปิด) ---&#xA;    xlWorkBook.Save()&#xA;    Console.WriteLine(&quot;✅ เทสีและ Save ไฟล์เรียบร้อยแล้ว (ไฟล์ยังเปิดอยู่)&quot;)&#xA;&#xA;Catch ex As Exception&#xA;    ' จัดการเมื่อเกิด Error&#xA;    out_IsSuccess = False&#xA;    out_ErrorMessage = ex.Message&#xA;    Console.WriteLine(&quot;❌ เกิดข้อผิดพลาด: &quot; &amp; out_ErrorMessage)&#xA;&#xA;Finally&#xA;    ' 7. คืนค่า Memory ให้ระบบอย่างเดียว &#xA;    If xlWorkSheet IsNot Nothing Then System.Runtime.InteropServices.Marshal.ReleaseComObject(xlWorkSheet)&#xA;    If xlWorkBook IsNot Nothing Then System.Runtime.InteropServices.Marshal.ReleaseComObject(xlWorkBook)&#xA;    If xlApp IsNot Nothing Then System.Runtime.InteropServices.Marshal.ReleaseComObject(xlApp)&#xA;    &#xA;    xlWorkSheet = Nothing&#xA;    xlWorkBook = Nothing&#xA;    xlApp = Nothing&#xA;End Try" DisplayName="FILL COLOR" sap:VirtualizedContainerService.HintSize="416,197" sap2010:WorkflowViewState.IdRef="InvokeCode_33">
