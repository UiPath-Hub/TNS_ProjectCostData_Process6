                                                    <ui:InvokeCode ContinueOnError="{x:Null}" Code="' ประกาศตัวแปร COM Objects&#xA;Dim excelApp As Microsoft.Office.Interop.Excel.Application = Nothing&#xA;Dim wb As Microsoft.Office.Interop.Excel.Workbook = Nothing&#xA;Dim ws As Microsoft.Office.Interop.Excel.Worksheet = Nothing&#xA;Dim targetCell As Microsoft.Office.Interop.Excel.Range = Nothing&#xA;Dim tempCellForLetter As Microsoft.Office.Interop.Excel.Range = Nothing&#xA;&#xA;Try&#xA;    ' เริ่มต้น Excel Application&#xA;    excelApp = New Microsoft.Office.Interop.Excel.Application()&#xA;    excelApp.Visible = False&#xA;    excelApp.DisplayAlerts = False&#xA;    excelApp.ScreenUpdating = False&#xA;&#xA;    ' เปิดไฟล์และเลือก Sheet&#xA;    wb = excelApp.Workbooks.Open(in_FilePath)&#xA;    ws = CType(wb.Sheets(in_SheetName), Microsoft.Office.Interop.Excel.Worksheet)&#xA;&#xA;    ' --- 1. หาเลขคอลัมน์สุดท้าย (ตัวเลข) ---&#xA;    targetCell = CType(ws.Cells(in_RowNumber, ws.Columns.Count), Microsoft.Office.Interop.Excel.Range)&#xA;    Dim lastColIndex As Integer = targetCell.End(Microsoft.Office.Interop.Excel.XlDirection.xlToLeft).Column&#xA;    &#xA;    ' --- 2. แปลงตัวเลขเป็นตัวอักษร (Alphabet) ---&#xA;    ' หลักการ: สร้าง Range ที่ Row 1 ของคอลัมน์นั้น แล้วดึง Address (เช่น $AA$1) มาตัด String&#xA;    tempCellForLetter = CType(ws.Cells(1, lastColIndex), Microsoft.Office.Interop.Excel.Range)&#xA;    Dim address As String = tempCellForLetter.Address ' ผลลัพธ์จะได้ประมาณ &quot;$AA$1&quot;&#xA;    &#xA;    ' ใช้ Split เพื่อแยกด้วยเครื่องหมาย $ จะได้ Array(&quot;&quot;, &quot;AA&quot;, &quot;1&quot;)&#xA;    ' ตัวอักษรจะอยู่ที่ Index 1 เสมอ&#xA;    out_LastColLetter = Split(address, &quot;$&quot;)(1)&#xA;&#xA;    Console.WriteLine(&quot;Last Column Index: &quot; &amp; lastColIndex &amp; &quot; | Letter: &quot; &amp; out_LastColLetter)&#xA;&#xA;Catch ex As Exception&#xA;&#x9;out_ErrorMessage = ex.Message&#xA;    Console.WriteLine(&quot;Error: &quot; &amp; ex.Message)&#xA;    'Throw ex&#xA;Finally&#xA;    ' Clean up Resources&#xA;    If tempCellForLetter IsNot Nothing Then System.Runtime.InteropServices.Marshal.ReleaseComObject(tempCellForLetter)&#xA;    If targetCell IsNot Nothing Then System.Runtime.InteropServices.Marshal.ReleaseComObject(targetCell)&#xA;    If ws IsNot Nothing Then System.Runtime.InteropServices.Marshal.ReleaseComObject(ws)&#xA;    &#xA;    If wb IsNot Nothing Then&#xA;        wb.Close(False)&#xA;        System.Runtime.InteropServices.Marshal.ReleaseComObject(wb)&#xA;    End If&#xA;&#xA;    If excelApp IsNot Nothing Then&#xA;        excelApp.Quit()&#xA;        System.Runtime.InteropServices.Marshal.ReleaseComObject(excelApp)&#xA;    End If&#xA;    &#xA;    GC.Collect()&#xA;    GC.WaitForPendingFinalizers()&#xA;End Try" DisplayName="Invoke Code for Get Last Column" sap:VirtualizedContainerService.HintSize="416,57" sap2010:WorkflowViewState.IdRef="InvokeCode_7">
