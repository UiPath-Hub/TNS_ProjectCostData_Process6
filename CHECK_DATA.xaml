el.XlFindLookIn.xlValues, &#xA;                LookAt:=Microsoft.Office.Interop.Excel.XlLookAt.xlWhole&#xA;            )&#xA;            &#xA;            ' หากพบคำนั้นใน Sheet&#xA;            If foundCell IsNot Nothing Then&#xA;                ' ดึงหมายเลขคอลัมน์จากเซลล์ที่เจอ&#xA;                Dim colIndex As Integer = foundCell.Column&#xA;                &#xA;                Dim targetCell As Microsoft.Office.Interop.Excel.Range &#xA;                targetCell = CType(ws.Cells(ws.Rows.Count, colIndex), Microsoft.Office.Interop.Excel.Range)&#xA;                &#xA;                ' หาแถวสุดท้ายของคอลัมน์นั้น&#xA;                Dim currentLastRow As Integer = targetCell.End(Microsoft.Office.Interop.Excel.XlDirection.xlUp).Row&#xA;                &#xA;                ' เปรียบเทียบและเก็บค่า Last Row ที่มากที่สุด (ลึกที่สุด)&#xA;                If currentLastRow &gt; maxLastRow Then&#xA;                    maxLastRow = currentLastRow&#xA;                End If&#xA;                &#xA;                ' คืนทรัพยากรตัวแปรเซลล์ที่หาเจอ&#xA;                System.Runtime.InteropServices.Marshal.ReleaseComObject(foundCell)&#xA;            Else&#xA;                ' หากไม่พบคำนั้น ให้เขียนแจ้งเตือนใน Console (ไม่ Error แต่จะข้ามไปหาคำต่อไป)&#xA;                Console.WriteLine(&quot;Warning: Not found value '&quot; &amp; cleanKey &amp; &quot;' in sheet.&quot;)&#xA;            End If&#xA;        End If&#xA;    Next&#xA;    &#xA;    ' หากไม่พบข้อมูลเลย หรือมีแต่ไฟล์ว่าง ให้คืนค่าเป็น 1&#xA;    If maxLastRow = 0 Then maxLastRow = 1&#xA;    &#xA;    out_LastRow = maxLastRow&#xA;    ' ---------------------------------------------------------------&#xA;&#xA;Catch ex As Exception&#xA;    out_ErrorMessage = ex.Message&#xA;    Console.WriteLine(&quot;Error: &quot; &amp; ex.Message)&#xA;    &#xA;Finally&#xA;    ' คืนทรัพยากร (ปิดไฟล์โดยไม่ Save การปลด Filter จะไม่กระทบไฟล์ต้นฉบับ)&#xA;    If wb IsNot Nothing Then&#xA;        wb.Close(False)&#xA;    End If&#xA;    &#xA;    excelA